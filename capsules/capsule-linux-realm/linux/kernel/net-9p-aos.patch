diff --git a/net/9p/Kconfig b/net/9p/Kconfig
index 00ebce9e5fa8..edcfd2a0af37 100644
--- a/net/9p/Kconfig
+++ b/net/9p/Kconfig
@@ -27,0 +28,9 @@
+config NET_9P_AOS
+	bool "AOS Realm SBI transport"
+	depends on RISCV && RISCV_SBI
+	help
+	  This builds the synchronous private-SBI transport used by the AOS
+	  RV64 Realm machine. It exposes no socket, block device, DMA queue,
+	  or physical host path; the outer Realm serves each bounded message
+	  through an already-authorized principal filesystem capability.
+
